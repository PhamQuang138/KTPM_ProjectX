generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  bannerImage String?
  bio       String?  @db.Text
  location  String?
  focusBrands String[] @default([])
  isVerifiedProfessional Boolean @default(false)
  role      UserRole @default(USER)
  posts     Post[]
  postLikes PostLike[]
  postComments PostComment[]
  postShares PostShare[]
  passwordResetTokens PasswordResetToken[]
  ratingsGiven UserRating[] @relation("RatingsGiven")
  ratingsReceived UserRating[] @relation("RatingsReceived")
  following UserFollow[] @relation("Following")
  followers UserFollow[] @relation("Followers")
  vehicles  Vehicle[]
  garageVehicles GarageVehicle[]
  vehicleListings VehicleListing[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model UserFollow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("user_follows")
}

model UserRating {
  id           String   @id @default(uuid())
  raterId      String
  targetUserId String
  score        Int
  rater        User     @relation("RatingsGiven", fields: [raterId], references: [id], onDelete: Cascade)
  targetUser   User     @relation("RatingsReceived", fields: [targetUserId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([raterId, targetUserId])
  @@index([targetUserId])
  @@map("user_ratings")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Post {
  id        String     @id @default(uuid())
  title     String
  content   String     @db.Text
  summary   String?
  status    PostStatus @default(DRAFT)
  authorId  String
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  images    Image[]
  likes     PostLike[]
  comments  PostComment[]
  shares    PostShare[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([authorId])
  @@index([status])
  @@map("posts")
}

model PostLike {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([postId, userId])
  @@index([userId])
  @@map("post_likes")
}

model PostComment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  postId    String
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@index([userId])
  @@map("post_comments")
}

model PostShare {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([userId])
  @@map("post_shares")
}

model Image {
  id        String   @id @default(uuid())
  url       String
  publicId  String?
  caption   String?
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId])
  @@map("images")
}

model Vehicle {
  id        String   @id @default(uuid())
  title     String
  price     String
  location  String
  image     String
  images    String[] @default([])
  condition String   @default("Used")
  category  String   @default("Daily")
  specs     String[] @default([])
  status    String   @default("Active Listing")
  sellerId  String
  seller    User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId])
  @@index([category])
  @@map("vehicles")
}

model GarageVehicle {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  image       String
  images      String[] @default([])
  condition   String   @default("Used")
  specs       String[] @default([])
  status      String   @default("In Garage")
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  listings    VehicleListing[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
  @@map("garage_vehicles")
}

model VehicleListing {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  price       String
  location    String
  category    String   @default("Daily")
  status      String   @default("Active Listing")
  sellerId    String
  seller      User     @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  vehicleId   String?
  vehicle     GarageVehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sellerId])
  @@index([vehicleId])
  @@index([category])
  @@map("vehicle_listings")
}
