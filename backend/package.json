{
  "name": "ktpm-backend",
  "private": true,
  "version": "0.0.0",
  "main": "dist/local-server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/local-server.ts",
    "postinstall": "prisma generate",
    "clean": "rimraf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "vercel-build": "prisma migrate deploy && npm run build",
    "start": "node dist/local-server.js",
    "lint": "tsc --noEmit -p tsconfig.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:drop-schema": "ts-node-dev --transpile-only --exit-child scripts/drop-app-schema.ts",
    "db:reset-data": "ts-node-dev --transpile-only --exit-child scripts/reset-db.ts",
    "db:ensure-admin": "ts-node-dev --transpile-only --exit-child scripts/ensure-admin.ts",
    "db:ensure-articles": "ts-node-dev --transpile-only --exit-child scripts/ensure-articles.ts",
    "db:migrate-images": "ts-node-dev --transpile-only --exit-child scripts/migrate-images-to-blob.ts",
    "db:seed-marketplace": "ts-node --transpile-only scripts/seed-marketplace-catalog.ts",
    "db:seed-marketplace-asia": "ts-node --transpile-only scripts/seed-marketplace-asia.ts",
    "db:seed-community-asia-extra": "ts-node --transpile-only scripts/seed-community-and-asia-extra.ts",
    "db:backfill-vehicle-search": "ts-node --transpile-only scripts/backfill-vehicle-search-metadata.ts",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@google/genai": "^1.52.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vercel/blob": "^2.4.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.10",
    "pg": "^8.21.0",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "prisma": "^7.8.0",
    "rimraf": "^6.0.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "~5.8.2"
  },
  "prisma": {
    "seed": "ts-node-dev --transpile-only --exit-child prisma/seed.ts"
  }
}
