NODE_ENV=production
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB_NAME?sslmode=require
CORS_ORIGIN=https://YOUR-PROJECT.vercel.app,https://YOUR-PROJECT-*.vercel.app
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-your-admin-password
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
LOG_LEVEL=info

# Vercel tự thêm biến này khi liên kết Blob Store với project.
# BLOB_READ_WRITE_TOKEN=
