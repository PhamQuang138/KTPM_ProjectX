NODE_ENV=production
HOST=0.0.0.0
PORT=8080

# Your deployed Vercel frontend URL.
CORS_ORIGIN=https://YOUR-VERCEL-PROJECT.vercel.app

# Your deployed Fly backend URL.
PUBLIC_BACKEND_URL=https://YOUR-FLY-APP.fly.dev

DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DB_NAME?sslmode=verify-full

JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d

ADMIN_USERNAME=admin
ADMIN_PASSWORD=12345

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
LOG_LEVEL=info

# Optional mail provider settings.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="CarHub <your-email@gmail.com>"
